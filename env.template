# P10-AlphaRadar Environment Configuration
# Copy to .env and fill in actual values

# === Database ===
DATABASE_URL=postgresql://radar:yourpassword@localhost:5433/alpharadar

# === Data Sources (A-share) ===
TUSHARE_TOKEN=your_tushare_pro_token

# === Data Sources (US stock) ===
# yfinance: no token needed
# Polygon.io (optional, for better US data): 
# POLYGON_API_KEY=your_polygon_key

# === Telegram ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === LLM - DeepSeek V3.2 (primary analysis, via 火山引擎 Ark) ===
DEEPSEEK_API_KEY=your_ark_api_key
DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DEEPSEEK_MODEL=deepseek-v3-2-251201

# === LLM - Doubao Seed 2.0 (backup analysis, via 火山引擎 Ark) ===
DOUBAO_API_KEY=your_ark_api_key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# === LLM - Qwen-Turbo (lightweight tasks, fast + cheap) ===
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo-latest

# === LLM - Embedding ===
EMBEDDING_API_KEY=your_qwen_api_key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# === P6+ Migration (one-time use) ===
P6_DUCKDB_PATH=/path/to/p6plus/data/agu.duckdb

# === Runtime ===
LOG_LEVEL=INFO
TIMEZONE=Asia/Shanghai
